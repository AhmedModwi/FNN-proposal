---
interface Source {
  title: string;
  url?: string;
}

interface Props {
  sources: Source[];
}

const { sources } = Astro.props;
---

<details class="group bg-surface border border-subtle rounded-xl overflow-hidden [&_summary::-webkit-details-marker]:hidden">
  <summary class="flex items-center justify-between p-4 font-semibold text-secondary cursor-pointer hover:bg-muted transition-colors">
    <div class="flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"></path>
      </svg>
      المراجع والدراسات الداعمة
    </div>
    <span class="transition group-open:rotate-180">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m6 9 6 6 6-6"></path>
      </svg>
    </span>
  </summary>
  <div class="p-4 pt-0 border-t border-subtle mt-2 text-sm text-secondary bg-muted/30">
    <ul class="space-y-3 mt-4 list-disc list-inside">
      {sources.map((source) => (
        <li>
          {source.url ? (
            <a href={source.url} target="_blank" rel="noopener noreferrer" class="hover:text-[#9B2226] hover:underline decoration-subtle underline-offset-4 transition-colors">
              {source.title}
            </a>
          ) : (
            <span>{source.title}</span>
          )}
        </li>
      ))}
    </ul>
  </div>
</details>
