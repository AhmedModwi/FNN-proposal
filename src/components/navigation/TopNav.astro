---
const navItems = [
  { labelAr: 'الرئيسية', labelEn: 'Overview', href: '/' },
  { labelAr: 'الألوان', labelEn: 'Color', href: '/color' },
  { labelAr: 'الخطوط', labelEn: 'Fonts', href: '/typography' },
  { labelAr: 'الصور', labelEn: 'Photography', href: '/photography' },
  { labelAr: 'الهيكلة', labelEn: 'Structure', href: '/structure' },
  { labelAr: 'الحركة', labelEn: 'Motion', href: '/motion' },
  { labelAr: 'القرارات', labelEn: 'Decisions', href: '/decisions' },
  { labelAr: 'المرحلة القادمة', labelEn: 'Next Phase', href: '/next-phase' },
];

const currentPath = Astro.url.pathname;
---

<header id="top-nav" class="fixed top-0 inset-x-0 z-50 transition-transform duration-300 bg-surface/90 backdrop-blur-md border-b border-subtle shadow-sm">
  <div class="max-w-[1600px] mx-auto px-4 lg:px-8 h-16 flex items-center justify-between gap-4">
    <!-- Logo / Brand -->
    <a href="/" class="flex items-center gap-2 group shrink-0">
      <div class="w-8 h-8 rounded-full bg-[#9B2226] flex items-center justify-center text-white font-bold text-sm group-hover:bg-[#7a1a1e] transition-colors">
        FNN
      </div>
      <span class="font-bold text-lg tracking-tight lang-ar pb-1">الفنانين</span>
      <span class="font-bold text-lg tracking-tight lang-en hidden">Al-Fananin</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden lg:flex flex-1 justify-center items-center gap-3 xl:gap-6">
      {navItems.map((item) => {
        const isActive = currentPath === item.href;
        return (
          <a 
            href={item.href} 
            class={`text-[13px] xl:text-sm font-semibold transition-colors hover:text-[#9B2226] relative py-2 whitespace-nowrap ${isActive ? 'text-[#9B2226]' : 'text-secondary'}`}
          >
            <span class="lang-ar">{item.labelAr}</span>
            <span class="lang-en hidden">{item.labelEn}</span>
            {isActive && (
              <span class="absolute bottom-0 inset-x-0 h-0.5 bg-[#9B2226] rounded-t-full"></span>
            )}
          </a>
        );
      })}
    </nav>

    <!-- Right Side: Lang Toggle & Mobile Menu -->
    <div class="flex items-center gap-3 shrink-0">
      <button id="lang-toggle-btn" class="flex items-center gap-1.5 px-3 py-1.5 rounded-md border border-subtle text-sm font-medium hover:bg-subtle transition-colors cursor-pointer text-secondary hover:text-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m5 8 6 6"/><path d="m4 14 6-6 2-3"/><path d="M2 5h12"/><path d="M7 2h1"/><path d="m22 22-5-10-5 10"/><path d="M14 18h6"/></svg>
        <span class="lang-ar">English</span>
        <span class="lang-en hidden">عربي</span>
      </button>

      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="lg:hidden p-2 text-secondary hover:text-primary transition-colors cursor-pointer" aria-label="Open menu">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" x2="20" y1="12" y2="12"></line>
          <line x1="4" x2="20" y1="6" y2="6"></line>
          <line x1="4" x2="20" y1="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Nav Sheet -->
  <div id="mobile-nav" class="fixed inset-x-0 top-0 h-auto max-h-screen bg-surface z-40 transition-transform duration-300 transform -translate-y-full lg:hidden flex flex-col pt-20 px-6 shadow-xl border-b border-subtle">
    <button id="close-menu-btn" class="absolute top-4 rtl:right-6 ltr:left-6 p-2 text-secondary hover:text-primary cursor-pointer" aria-label="Close menu">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18 6 6 18"></path>
        <path d="m6 6 12 12"></path>
      </svg>
    </button>
    <nav class="flex flex-col gap-6 text-xl overflow-y-auto pb-20 mt-4">
      {navItems.map((item) => (
        <a href={item.href} class={`font-semibold hover:text-[#9B2226] border-b border-subtle pb-4 ${currentPath === item.href ? 'text-[#9B2226]' : 'text-primary'}`}>
          <span class="lang-ar">{item.labelAr}</span>
          <span class="lang-en hidden">{item.labelEn}</span>
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  // Hide on scroll logic
  let lastScrollY = window.scrollY;
  const nav = document.getElementById('top-nav');
  
  if (nav) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > lastScrollY && window.scrollY > 80) {
        nav.style.transform = 'translateY(-100%)';
      } else {
        nav.style.transform = 'translateY(0)';
      }
      lastScrollY = window.scrollY;
    }, { passive: true });
  }

  // Language Toggle Logic
  const langToggleBtn = document.getElementById('lang-toggle-btn');
  if (langToggleBtn) {
    langToggleBtn.addEventListener('click', () => {
      const currentLang = document.documentElement.lang;
      const newLang = currentLang === 'ar' ? 'en' : 'ar';
      
      localStorage.setItem('fnn-lang', newLang);
      document.documentElement.lang = newLang;
      document.documentElement.dir = newLang === 'ar' ? 'rtl' : 'ltr';
    });
  }

  // Mobile menu logic
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const closeBtn = document.getElementById('close-menu-btn');
  const mobileNav = document.getElementById('mobile-nav');

  if (mobileBtn && closeBtn && mobileNav) {
    mobileBtn.addEventListener('click', () => {
      mobileNav.style.transform = 'translateY(0)';
      document.body.style.overflow = 'hidden';
    });
    
    closeBtn.addEventListener('click', () => {
      mobileNav.style.transform = 'translateY(-100%)';
      document.body.style.overflow = '';
    });
  }
</script>
