---
import BaseLayout from '../layouts/BaseLayout.astro';
import SourceLinks from '../components/ui/SourceLinks.astro';
---

<BaseLayout title="Motion & Micro-interactions System — Al-Fananin">
  <style is:global>

        body {
            color: var(--color-text-primary);
            background-color: var(--color-bg-base);
        }

        .en-font {
            font-family: 'Inter', system-ui, sans-serif;
            direction: ltr;
            display: inline-block;
        }

        .doc-container {
            max-width: 1040px;
            margin: 0 auto;
            padding: 0 2rem;
        }

        section {
            padding: 5rem 0;
            border-bottom: 1px solid var(--border-light);
        }

        section:last-of-type {
            border-bottom: none;
        }

        .section-header {
            margin-bottom: 3.5rem;
            max-width: 800px;
        }

        .section-num {
            font-family: 'Inter', sans-serif;
            font-weight: 700;
            color: var(--text-muted);
            font-size: 0.875rem;
            letter-spacing: 0.05em;
            margin-bottom: 0.75rem;
            display: block;
        }

        .section-title {
            font-size: 2.25rem;
            font-weight: bold;
            margin-bottom: 1.25rem;
            line-height: 1.3;
        }

        .section-desc {
            font-size: 1.125rem;
            color: var(--text-muted);
        }

        .tag {
            font-family: 'Inter', sans-serif;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            padding: 0.25rem 0.5rem;
            border-radius: 4px;
            background: rgba(43, 26, 20, 0.05);
            color: var(--text-muted);
        }

        /* Motion Preview Utilities */
        .preview-box {
            background: white;
            border: 1px solid var(--border-light);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            min-height: 160px;
        }

        .motion-fast { transition: all var(--transition-fast) ease-in-out; }
        .motion-base { transition: all var(--transition-base) ease-in-out; }
        .motion-slow { transition: all var(--transition-slow) cubic-bezier(0.4, 0, 0.2, 1); }

        /* Generic UI Elements for demos */
        .demo-btn {
            background-color: var(--text-main);
            color: white;
            padding: 0.5rem 1.5rem;
            border-radius: 999px;
            font-family: 'Inter', sans-serif;
            font-size: 0.875rem;
            cursor: pointer;
            border: none;
        }
        
        .demo-btn:hover {
            transform: scale(0.98);
            opacity: 0.9;
        }

        .demo-card {
            background: white;
            border: 1px solid var(--border-light);
            border-radius: 8px;
            padding: 1rem;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
            cursor: pointer;
        }
        
        .demo-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        }

        .skeleton {
            background: #e2e8f0;
            position: relative;
            overflow: hidden;
        }
        
        .skeleton::after {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            bottom: 0;
            left: 0;
            transform: translateX(-100%);
            background-image: linear-gradient(
                90deg,
                rgba(255, 255, 255, 0) 0,
                rgba(255, 255, 255, 0.5) 20%,
                rgba(255, 255, 255, 0.5) 60%,
                rgba(255, 255, 255, 0)
            );
            animation: shimmer 2s infinite;
        }
        
        @keyframes shimmer {
            100% {
                transform: translateX(100%);
            }
        }

        /* Flow Diagram */
        .flow-step {
            position: relative;
        }
        .flow-step:not(:last-child)::after {
            content: '';
            position: absolute;
            top: 50%;
            left: -2rem;
            width: 2rem;
            height: 2px;
            background: var(--border-light);
            z-index: -1;
        }

        @media screen and (prefers-reduced-motion: reduce) {
            .motion-fast, .motion-base, .motion-slow, .demo-btn, .demo-card, .skeleton::after {
                transition: opacity calc(var(--transition-base) * 2) ease-in-out !important;
                transform: none !important;
                animation: none !important;
            }
        }
    
  </style>



    <header class="pt-24 pb-16 bg-white border-b border-gray-200">
        <div class="doc-container text-center">
            <span class="en-font text-xs font-bold tracking-widest uppercase text-gray-500 mb-6 block">UX Architecture Specification v1.0</span>
            <h1 class="text-4xl md:text-5xl font-bold mb-6"><span class="lang-ar">نظام الحركة والتفاعلات الدقيقة</span><span class="lang-en hidden">Motion system and micro interactions</span></h1>
            <p class="text-xl max-w-2xl mx-auto opacity-75 leading-relaxed">
                <span class="lang-ar">اللغة السلوكية التي تمنح الواجهة الوضوح والإحساس بالحياة</span><span class="lang-en hidden">Behavioral language that gives the interface clarity and a sense of life</span>
            </p>
        </div>
    </header>

    <main>
        <!-- RESEARCH-DRIVEN FOUNDATION -->
        <section class="bg-muted/50 border-b border-subtle py-16 md:py-24 px-6 md:px-12">
          <div class="max-w-7xl mx-auto">
            <div class="mb-12 max-w-4xl">
              <span class="en-text text-xs font-bold tracking-widest uppercase text-secondary mb-3 block" dir="ltr">Behavioral Engineering Foundations</span>
              <h2 class="text-3xl md:text-5xl font-black mb-6 f-amiri leading-[1.2]">
                <span class="lang-ar">إيقاعات الاستجابة الرقمية: <br/><span class="text-blue-600">لماذا تتحرك الواجهة بهذا الشكل؟</span></span>
                <span class="lang-en hidden" dir="ltr">Digital Response Rhythms: <br/><span class="text-blue-600">Why the UI Moves This Way?</span></span>
              </h2>
              <p class="text-xl md:text-2xl text-secondary leading-relaxed f-amiri border-r-4 border-blue-600/20 pr-6">
                <span class="lang-ar">بما أن</span><span class="lang-en hidden">Since</span> <strong><span class="lang-ar">72% من عمليات البحث عن المطاعم تتم عبر الجوال</span><span class="lang-en hidden">72% of restaurant searches happen on mobile</span></strong><span class="lang-ar">، فإن زمن الاستجابة (Pacing) يحدد مدى ثقة الضيف في كفاءة المطعم الرقمي. قمنا بهندسة التوقيتات بناءً على النتائج التالية:</span><span class="lang-en hidden">, response time (Pacing) determines the guest's trust in the digital efficiency. We engineered the timings based on these results:</span>
              </p>
            </div>

            <div class="grid md:grid-cols-3 gap-6">
              <div class="bg-white p-6 border rounded-xl shadow-sm">
                <h4 class="font-bold text-blue-600 mb-2 f-amiri ar-text"><span class="lang-ar">قانون الثواني (Reaction Time)</span><span class="lang-en hidden">Reaction Law</span></h4>
                <p class="text-xs opacity-80 leading-relaxed f-amiri ar-text"><span class="lang-ar">الاستجابة في أقل من 400ms تمنح المستخدم إحساساً "بالقدرة والتحكم". نظامنا يلتزم بـ 300ms كحد أقصى للعمليات القياسية، مما يجعل تصفح المنيو يبدو كالبرق.</span><span class="lang-en hidden">Response under 400ms gives the user a sense of "power and control". Our system commits to 300ms max for standard operations, making menu browsing lightning fast.</span></p>
              </div>
              <div class="bg-white p-6 border rounded-xl shadow-sm">
                <h4 class="font-bold text-blue-600 mb-2 f-amiri ar-text"><span class="lang-ar">ثقة التحميل (Loading Trust)</span><span class="lang-en hidden">Loading Trust</span></h4>
                <p class="text-xs opacity-80 leading-relaxed f-amiri ar-text"><span class="lang-ar">استخدام شاشات الهيكل (Skeletons) بدلاً من المؤشرات الدوارة يقلل من "الزمن المُدرك" للانتظار. هذا التكتيك السلوكي يحافظ على بقاء الضيف في الموقع لفترات أطول.</span><span class="lang-en hidden">Using Skeletons instead of spinners reduces "perceived wait time". This behavioral tactic keeps the guest on-site longer.</span></p>
              </div>
              <div class="bg-white p-6 border rounded-xl shadow-sm">
                <h4 class="font-bold text-blue-600 mb-2 f-amiri ar-text"><span class="lang-ar">انسيابية الـ RTL (RTL Flow)</span><span class="lang-en hidden">RTL Flow</span></h4>
                <p class="text-xs opacity-80 leading-relaxed f-amiri ar-text"><span class="lang-ar">عكس الحركات الاتجاهية للتوافق مع دفق قراءة الواجهة العربية يقلل من الجهد الذهني (Cognitive Load)، مما يسهل الوصول للمعلومات الأساسية (العنوان، المنيو) بسلاسة تامة.</span><span class="lang-en hidden">Mirroring movements for RTL flows reduces cognitive load, making access to key information (address, menu) perfectly seamless.</span></p>
              </div>
            </div>
          </div>
        </section>
        <!-- SECTION 1 & 2 -->
        <section class="doc-container">
            <div class="section-header">
                <span class="section-num en-font">SECTION 1.0 & 2.0</span>
                <h2 class="section-title"><span class="lang-ar">فلسفة الحركة ووظيفتها</span><span class="lang-en hidden">Movement philosophy and function</span></h2>
                <p class="section-desc">
                    <span class="lang-ar">الحركة في الواجهة ليست زينة بصرية، بل نظام سلوكي دقيق يوضح السبب والنتيجة، يؤكد نجاح التفاعل، يوجه الانتباه، ويحوّل الواجهة من سطح جامد إلى تجربة مفهومة وراقية. الحركة الصاخبة تشتت، بينما الحركة المنضبطة تطمئن.</span><span class="lang-en hidden">Movement in the interface is not a visual decoration, but rather a precise behavioral system that explains cause and effect, confirms the success of the interaction, directs attention, and transforms the interface from a rigid surface into an understandable and uplifting experience. Loud movement is distracting, while controlled movement is reassuring.</span>
                </p>
            </div>

            <div class="grid md:grid-cols-4 gap-6">
                <!-- Principles -->
                <div class="bg-white p-6 rounded-xl border border-gray-200">
                    <h3 class="font-bold text-lg mb-2"><span class="lang-ar">الوضوح</span><span class="lang-en hidden">Clarity</span></h3>
                    <p class="text-sm opacity-70 mb-4"><span class="lang-ar">يجب أن تشرح الحركة ما تغير في الواجهة ولماذا.</span><span class="lang-en hidden">The animation should explain what changed in the interface and why.</span></p>
                    <span class="tag">Feedback</span>
                </div>
                <div class="bg-white p-6 rounded-xl border border-gray-200">
                    <h3 class="font-bold text-lg mb-2"><span class="lang-ar">السبب والنتيجة</span><span class="lang-en hidden">Cause and effect</span></h3>
                    <p class="text-sm opacity-70 mb-4"><span class="lang-ar">الإجراء الذي يتخذه المستخدم يجب أن يولد استجابة مرئية فورية ومترابطة.</span><span class="lang-en hidden">The action the user takes must generate an immediate and relatable visual response.</span></p>
                    <span class="tag">Cause & Effect</span>
                </div>
                <div class="bg-white p-6 rounded-xl border border-gray-200">
                    <h3 class="font-bold text-lg mb-2"><span class="lang-ar">الانضباط</span><span class="lang-en hidden">Discipline</span></h3>
                    <p class="text-sm opacity-70 mb-4"><span class="lang-ar">الحركة اللانهائية أو الاستعراضية ممنوعة. الحركة تبدأ وتنتهي بهدف.</span><span class="lang-en hidden">Endless or reflexive movement is prohibited. Movement begins and ends with a goal.</span></p>
                    <span class="tag">Restraint</span>
                </div>
                <div class="bg-white p-6 rounded-xl border border-gray-200">
                    <h3 class="font-bold text-lg mb-2"><span class="lang-ar">المكافأة العاطفية</span><span class="lang-en hidden">Emotional reward</span></h3>
                    <p class="text-sm opacity-70 mb-4"><span class="lang-ar">توفير شعور بالرضا الخفي بعد إتمام مهام رئيسية بشكل يعكس الكرم والترحيب.</span><span class="lang-en hidden">Providing a sense of hidden satisfaction after completing key tasks in a way that reflects generosity and welcome.</span></p>
                    <span class="tag">Delight</span>
                </div>
            </div>
        </section>

        <!-- SECTION 3 -->
        <section class="bg-gray-50 border-y border-gray-200">
            <div class="doc-container">
                <div class="section-header">
                    <span class="section-num en-font">SECTION 3.0</span>
                    <h2 class="section-title"><span class="lang-ar">دورة التفاعل الدقيق ذات الـ 4 مراحل</span><span class="lang-en hidden">4-stage microreaction cycle</span></h2>
                    <p class="section-desc">
                        <span class="lang-ar">كل حركة ميكرو-تفاعلية مبنية على دورة منطقية متسلسلة لضمان عدم وجود حركة عبثية.</span><span class="lang-en hidden">Each micro-interactive movement is based on a sequential logical cycle to ensure that there is no frivolous movement.</span>
                    </p>
                </div>

                <div class="flex flex-col md:flex-row gap-4 items-stretch text-center justify-between mt-12 bg-white p-8 rounded-2xl shadow-sm border border-gray-100 relative">
                    
                    <div class="flex-1 flow-step bg-gray-50 p-6 rounded-xl border border-gray-200">
                        <span class="tag mb-3 block">Trigger</span>
                        <h4 class="font-bold flex items-center justify-center gap-2 mb-2"><i data-lucide="zap" class="w-4 h-4 text-amber-500"></i><span class="lang-ar">المُحفّز</span><span class="lang-en hidden">Catalyst</span></h4>
                        <p class="text-sm opacity-70"><span class="lang-ar">يبدأ من المستخدم (نقرة) أو النظام (اكتمال تحميل).</span><span class="lang-en hidden">It starts from the user (click) or system (download complete).</span></p>
                    </div>

                    <div class="flex-1 flow-step bg-gray-50 p-6 rounded-xl border border-gray-200">
                        <span class="tag mb-3 block">Rules</span>
                        <h4 class="font-bold flex items-center justify-center gap-2 mb-2"><i data-lucide="scale" class="w-4 h-4 text-blue-500"></i><span class="lang-ar">القواعد</span><span class="lang-en hidden">Rules</span></h4>
                        <p class="text-sm opacity-70"><span class="lang-ar">المنطق الخفي: מה يمكن أن يحدث وكيف؟ (مثل قيود الحجم والمسافة).</span><span class="lang-en hidden">Hidden logic: What can happen and how? (such as size and distance restrictions).</span></p>
                    </div>

                    <div class="flex-1 flow-step bg-gray-50 p-6 rounded-xl border border-gray-200">
                        <span class="tag mb-3 block">Feedback</span>
                        <h4 class="font-bold flex items-center justify-center gap-2 mb-2"><i data-lucide="eye" class="w-4 h-4 text-green-500"></i><span class="lang-ar">التأكيد المرئي</span><span class="lang-en hidden">Visual confirmation</span></h4>
                        <p class="text-sm opacity-70"><span class="lang-ar">الاستجابة الحركية التي يراها المستخدم، وتمنحه إحساساً بالتحكم.</span><span class="lang-en hidden">The kinetic response that the user sees, and gives him a sense of control.</span></p>
                    </div>

                    <div class="flex-1 bg-gray-50 p-6 rounded-xl border border-gray-200">
                        <span class="tag mb-3 block">Loops & Modes</span>
                        <h4 class="font-bold flex items-center justify-center gap-2 mb-2"><i data-lucide="repeat-1" class="w-4 h-4 text-purple-500"></i><span class="lang-ar">التكرار والحالة</span><span class="lang-en hidden">Recurrence and status</span></h4>
                        <p class="text-sm opacity-70"><span class="lang-ar">هل تتكرر الحركة؟ (يفضل دائماً: مرة واحدة).</span><span class="lang-en hidden">Is the movement repeated? (Always prefer: once).</span></p>
                    </div>

                </div>
            </div>
        </section>

        <!-- SECTION 4 -->
        <section class="doc-container">
            <div class="section-header">
                <span class="section-num en-font">SECTION 4.0</span>
                <h2 class="section-title"><span class="lang-ar">قانون الزمن: وحدات الحركة التأسيسية</span><span class="lang-en hidden">The law of time: constituent units of motion</span></h2>
                <p class="section-desc">
                    <span class="lang-ar">السرعات العشوائية مرفوضة. يتم تعريف جميع الحركات من خلال ثلاث وحدات زمنية صارمة لضمان الاتساق والإيقاع الدقيق في كامل النظام.</span><span class="lang-en hidden">Random speeds are rejected. All movements are defined by three strict time units to ensure consistency and precise rhythm throughout the system.</span>
                </p>
            </div>

            <div class="grid md:grid-cols-3 gap-8">
                <!-- Fast -->
                <div class="border border-gray-200 rounded-xl p-6 bg-white shadow-sm hover:shadow-md motion-base cursor-pointer group">
                    <div class="flex justify-between items-center mb-6 border-b pb-4">
                        <h3 class="font-bold text-lg"><span class="lang-ar">سريع وانعكاسي</span><span class="lang-en hidden">Fast and reflexive</span></h3>
                        <span class="en-font font-bold text-gray-800 text-xl border rounded px-2">150ms</span>
                    </div>
                    <span class="tag mb-4 inline-block">--transition-fast</span>
                    <ul class="text-sm opacity-80 space-y-2 mb-6 list-disc list-inside">
                        <li><span class="lang-ar">تأثيرات المرور (Hover).</span><span class="lang-en hidden">Hover effects.</span></li>
                        <li><span class="lang-ar">حالات التفعيل الفورية (Active states).</span><span class="lang-en hidden">Active states.</span></li>
                        <li><span class="lang-ar">تغير ألوان الأيقونات.</span><span class="lang-en hidden">Change icon colors.</span></li>
                    </ul>
                    <div class="preview-box bg-gray-50 flex-col gap-2">
                        <button class="bg-gray-200 hover:bg-gray-300 text-gray-800 font-bold py-2 px-4 rounded motion-fast">Hover Me</button>
                    </div>
                </div>

                <!-- Base -->
                <div class="border border-gray-200 rounded-xl p-6 bg-white shadow-sm hover:shadow-md motion-base cursor-pointer group">
                    <div class="flex justify-between items-center mb-6 border-b pb-4">
                        <h3 class="font-bold text-lg"><span class="lang-ar">القياسي</span><span class="lang-en hidden">Standard</span></h3>
                        <span class="en-font font-bold text-gray-800 text-xl border rounded px-2">300ms</span>
                    </div>
                    <span class="tag mb-4 inline-block">--transition-base</span>
                    <ul class="text-sm opacity-80 space-y-2 mb-6 list-disc list-inside">
                        <li><span class="lang-ar">تبديل الأيقونات والرموز.</span><span class="lang-en hidden">Toggle icons and icons.</span></li>
                        <li><span class="lang-ar">القفزات البيسطة (Subtle bounce).</span><span class="lang-en hidden">Subtle bounce.</span></li>
                        <li><span class="lang-ar">تغيرات الظلال والأسطح.</span><span class="lang-en hidden">Changes in shadows and surfaces.</span></li>
                    </ul>
                    <div class="preview-box bg-gray-50">
                       <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center text-blue-600 motion-base group-hover:scale-110 group-hover:bg-blue-200">
                           <i data-lucide="check" class="w-8 h-8 opacity-0 group-hover:opacity-100 motion-base absolute"></i>
                           <i data-lucide="circle" class="w-8 h-8 group-hover:opacity-0 motion-base absolute"></i>
                       </div>
                    </div>
                </div>

                <!-- Slow -->
                <div class="border border-gray-200 rounded-xl p-6 bg-white shadow-sm hover:shadow-md motion-base cursor-pointer group">
                    <div class="flex justify-between items-center mb-6 border-b pb-4">
                        <h3 class="font-bold text-lg"><span class="lang-ar">متأنٍ واستعراضي</span><span class="lang-en hidden">Careful and showcasing</span></h3>
                        <span class="en-font font-bold text-gray-800 text-xl border rounded px-2">500ms</span>
                    </div>
                    <span class="tag mb-4 inline-block">--transition-slow</span>
                    <ul class="text-sm opacity-80 space-y-2 mb-6 list-disc list-inside">
                        <li><span class="lang-ar">دخول النوافذ المنبثقة (Modals).</span><span class="lang-en hidden">Enter pop-up windows (Modals).</span></li>
                        <li><span class="lang-ar">الأدراج الجانبية (Drawers).</span><span class="lang-en hidden">Side drawers.</span></li>
                        <li><span class="lang-ar">كشف الأقسام الرئيسية في الصفحة.</span><span class="lang-en hidden">Reveal the main sections of the page.</span></li>
                    </ul>
                    <div class="preview-box bg-gray-50 overflow-hidden relative">
                        <div class="w-full h-full bg-white absolute -bottom-full group-hover:bottom-0 motion-slow rounded-t-xl border-t shadow-lg flex items-center justify-center">
                            <span class="text-sm font-bold text-gray-500">Drawer Revealed</span>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- SECTION 5, 6, 7 -->
        <section class="bg-gray-50 border-y border-gray-200">
            <div class="doc-container">
                <div class="section-header">
                    <span class="section-num en-font">SECTION 5.0, 6.0, 7.0</span>
                    <h2 class="section-title"><span class="lang-ar">تصنيف المُحفّزات (Triggers)</span><span class="lang-en hidden">Classification of triggers</span></h2>
                    <p class="section-desc"><span class="lang-ar">تنقسم أسباب الحركة إلى نوعين رئيسيين يتبعان مصدر إثارة الحدث.</span><span class="lang-en hidden">The causes of movement are divided into two main types that follow the source of the excitement of the event.</span></p>
                </div>

                <div class="grid md:grid-cols-2 gap-12">
                    
                    <!-- User Triggers -->
                    <div>
                        <div class="flex items-center gap-3 mb-6">
                            <div class="w-10 h-10 rounded-full bg-teal-100 flex items-center justify-center text-teal-700"><i data-lucide="mouse-pointer-2" class="w-5 h-5"></i></div>
                            <h3 class="text-2xl font-bold"><span class="lang-ar">محفزات يعتمدها المستخدم</span><span class="lang-en hidden">User-dependent triggers</span></h3>
                        </div>
                        <p class="mb-6 opacity-80"><span class="lang-ar">أفعال مباشرة تبدأ بقرار بشري. تتطلب استجابة سريعة جداً وواضحة.</span><span class="lang-en hidden">Direct actions that begin with a human decision. It requires a very quick and clear response.</span></p>
                        
                        <div class="space-y-4">
                            <div class="bg-white p-4 border rounded-lg flex items-center justify-between">
                                <div><strong class="block"><span class="lang-ar">النقر (Click / Tap)</span><span class="lang-en hidden">Click / Tap</span></strong><span class="text-sm opacity-60"><span class="lang-ar">يؤدي إلى انكماش مرن (Compression) واعتراف باللمس.</span><span class="lang-en hidden">It leads to elastic contraction and tactile recognition.</span></span></div>
                                <span class="tag">User-Triggered</span>
                            </div>
                            <div class="bg-white p-4 border rounded-lg flex items-center justify-between">
                                <div><strong class="block"><span class="lang-ar">المرور (Hover)</span><span class="lang-en hidden">Hover</span></strong><span class="text-sm opacity-60"><span class="lang-ar">تلميح بصري ناعم يؤكد قابلية النقر.</span><span class="lang-en hidden">Soft visual cue emphasizes clickability.</span></span></div>
                                <span class="tag">User-Triggered</span>
                            </div>
                            <div class="bg-white p-4 border rounded-lg flex items-center justify-between">
                                <div><strong class="block"><span class="lang-ar">التمرير (Swipe / Scroll)</span><span class="lang-en hidden">Scrolling (Swipe / Scroll)</span></strong><span class="text-sm opacity-60"><span class="lang-ar">حركة مرتبطة بمسافة سحب الأصبع أو الفأرة.</span><span class="lang-en hidden">Movement related to the distance of a finger or mouse drag.</span></span></div>
                                <span class="tag">User-Triggered</span>
                            </div>
                        </div>
                    </div>

                    <!-- System Triggers -->
                    <div>
                        <div class="flex items-center gap-3 mb-6">
                            <div class="w-10 h-10 rounded-full bg-amber-100 flex items-center justify-center text-amber-700"><i data-lucide="server" class="w-5 h-5"></i></div>
                            <h3 class="text-2xl font-bold"><span class="lang-ar">محفزات يعتمدها النظام</span><span class="lang-en hidden">System-based incentives</span></h3>
                        </div>
                        <p class="mb-6 opacity-80"><span class="lang-ar">أحداث تحدث بالخلفية بدون تدخل فوري. تتطلب حركات تلفت الانتباه بلطف.</span><span class="lang-en hidden">Events that occur in the background without immediate intervention. Requires movements that gently attract attention.</span></p>
                        
                        <div class="space-y-4">
                            <div class="bg-white p-4 border rounded-lg flex items-center justify-between">
                                <div><strong class="block"><span class="lang-ar">التحميل (Data Loading)</span><span class="lang-en hidden">Data Loading</span></strong><span class="text-sm opacity-60"><span class="lang-ar">شاشات الهيكل (Skeleton) تطمئن بوجود بيانات قادمة.</span><span class="lang-en hidden">Skeleton displays reassure you that there is incoming data.</span></span></div>
