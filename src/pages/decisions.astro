---
import DecisionLayout from '../layouts/DecisionLayout.astro';
import DecisionCard from '../components/ui/DecisionCard.astro';
---

<DecisionLayout 
  titleAr="حسم الخيارات والموافقة النهائية" 
  titleEn="Final Decisions & Sign-off"
  descriptionAr="بناءً على تحليل بيانات الزوار (892 مراجعة) ودراسات علم النفس البصري، نقدم هنا المسار الموصى به للموافقة عليه."
  descriptionEn="Based on visitor data analysis (892 reviews) and visual psychology studies, we present the recommended path for approval."
>
  
  <!-- COLOR SYSTEMS CHOICE -->
  <section class="mb-12 bg-white p-8 rounded-2xl shadow-sm border border-subtle">
    <header class="mb-8 border-b pb-4">
      <h3 class="text-2xl font-black mb-2 f-amiri text-[#9B2226]">
        <span class="lang-ar">1. اختيار النظام اللوني (Color Systems)</span>
        <span class="lang-en hidden">1. Color System Selection</span>
      </h3>
      <p class="text-secondary f-amiri text-lg">
        <span class="lang-ar">يجب اختيار نظام لوني واحد ليكون الهوية البصرية الرسمية:</span>
        <span class="lang-en hidden">Select one color system to be the official visual identity:</span>
      </p>
    </header>

    <div class="grid md:grid-cols-2 gap-6">
      <!-- System 1: Heritage Warmth -->
      <div class="relative p-6 border-2 border-dashed rounded-2xl bg-[#FDFBF7] hover:border-[#9B2226] transition-all cursor-pointer group">
        <div class="absolute -top-3 right-4 bg-white px-2 text-xs font-bold text-gray-400 group-hover:text-[#9B2226]">Option A</div>
        <div class="flex gap-3 mb-4">
          <div class="w-12 h-12 rounded-full shadow-inner border border-black/5" style="background-color: #EEDCB5;"></div>
          <div class="w-12 h-12 rounded-full shadow-inner border border-black/5" style="background-color: #81B29A;"></div>
          <div class="w-12 h-12 rounded-full shadow-inner border border-black/5" style="background-color: #E07A5F;"></div>
        </div>
        <h4 class="text-xl font-bold mb-2 f-amiri"><span class="lang-ar">النظام الأول: الدفء التراثي (Heritage Warmth)</span><span class="lang-en hidden">System 1: Heritage Warmth</span></h4>
        <p class="text-sm opacity-75 f-amiri leading-relaxed mb-4">
          <span class="lang-ar">يعتمد على ألوان الأرض، الكسرة، والطوب. يوحي بالثقة، العراقة، والراحة العائلية. مثالي لجلسات الغداء الطويلة.</span>
          <span class="lang-en hidden">Based on earth tones, Kisra, and bricks. Suggests trust, heritage, and family comfort. Ideal for long lunch sessions.</span>
        </p>
        <div class="p-3 bg-white/50 rounded-lg text-xs font-bold text-center border">
          <span class="lang-ar">ألوان القراءة: بني داكن ورملي</span>
          <span class="lang-en hidden">Type Colors: Dark Brown & Sand</span>
        </div>
      </div>

      <!-- System 2: Vibrant Contrast -->
      <div class="relative p-6 border-2 border-dashed rounded-2xl bg-[#F7F9FD] hover:border-[#9B2226] transition-all cursor-pointer group">
        <div class="absolute -top-3 right-4 bg-white px-2 text-xs font-bold text-gray-400 group-hover:text-[#9B2226]">Option B</div>
        <div class="flex gap-3 mb-4">
          <div class="w-12 h-12 rounded-full shadow-inner border border-black/5" style="background-color: #E8B730;"></div>
          <div class="w-12 h-12 rounded-full shadow-inner border border-black/5" style="background-color: #E07A5F;"></div>
          <div class="w-12 h-12 rounded-full shadow-inner border border-black/5" style="background-color: #3D405B;"></div>
        </div>
        <h4 class="text-xl font-bold mb-2 f-amiri"><span class="lang-ar">النظام الثاني: التباين الحيوي (Vibrant Contrast)</span><span class="lang-en hidden">System 2: Vibrant Contrast</span></h4>
        <p class="text-sm opacity-75 f-amiri leading-relaxed mb-4">
          <span class="lang-ar">يعتمد على الذهب، الزعفران، والتباين العالي. يوحي بالطاقة، الحداثة، والمقهى الاجتماعي الصاخب.</span>
          <span class="lang-en hidden">Based on gold, saffron, and high contrast. Suggests energy, modernity, and a vibrant social cafe.</span>
        </p>
        <div class="p-3 bg-white/50 rounded-lg text-xs font-bold text-center border">
          <span class="lang-ar">ألوان القراءة: كحلي داكن وذهبي</span>
          <span class="lang-en hidden">Type Colors: Deep Navy & Gold</span>
        </div>
      </div>
    </div>
    
    <div class="mt-8 p-4 bg-red-50 border border-red-100 rounded-xl">
        <p class="text-sm f-amiri text-red-900 font-bold">
            <span class="lang-ar">توصية المستشار: نوصي بالنظام الأول (الدفء التراثي) لأنه يتسق مع رغبة 85% من زوار المطعم في الشعور بالأصالة والراحة.</span>
            <span class="lang-en hidden">Consultant recommendation: We recommend System 1 (Heritage Warmth) as it aligns with the desire of 85% of restaurant visitors for authenticity and comfort.</span>
        </p>
    </div>
  </section>

  <!-- TYPOGRAPHY SYSTEMS CHOICE -->
  <section class="mb-12 bg-white p-8 rounded-2xl shadow-sm border border-subtle">
    <header class="mb-8 border-b pb-4">
      <h3 class="text-2xl font-black mb-2 f-amiri text-[#9B2226]">
        <span class="lang-ar">2. اختيار نظام الخطوط (Typography Systems)</span>
        <span class="lang-en hidden">2. Font System Selection</span>
      </h3>
      <p class="text-secondary f-amiri text-lg">
        <span class="lang-ar">يجب اختيار تركيبة الخطوط المناسبة لشخصية العلامة:</span>
        <span class="lang-en hidden">Select the font combination that fits the brand personality:</span>
      </p>
    </header>

    <div class="grid md:grid-cols-2 gap-6">
      <!-- System 1: Heritage & Comfort -->
      <div class="relative p-6 border-2 border-dashed rounded-2xl hover:border-[#9B2226] transition-all cursor-pointer group">
        <div class="absolute -top-3 right-4 bg-white px-2 text-xs font-bold text-gray-400 group-hover:text-[#9B2226]">Option A</div>
        <div class="mb-4">
          <h2 class="text-3xl font-bold f-amiri mb-2">الخط الأميري (عناوين)</h2>
          <p class="text-sm opacity-60">Inter / Cairo (Body text)</p>
        </div>
        <h4 class="text-xl font-bold mb-2 f-amiri"><span class="lang-ar">نظام Heritage & Comfort</span><span class="lang-en hidden">Heritage & Comfort System</span></h4>
        <p class="text-sm opacity-75 f-amiri leading-relaxed">
          <span class="lang-ar">يركز على الجلال الثقافي، الخطوط الكلاسيكية، والقراءة المريحة. يربط الموقع بالكتب والمخطوطات التراثية السودانية.</span>
          <span class="lang-en hidden">Focuses on cultural majesty, classic fonts, and comfortable reading. Connects the site to Sudanese heritage manuscripts.</span>
        </p>
      </div>

      <!-- System 2: Modern & Friendly -->
      <div class="relative p-6 border-2 border-dashed rounded-2xl hover:border-[#9B2226] transition-all cursor-pointer group">
        <div class="absolute -top-3 right-4 bg-white px-2 text-xs font-bold text-gray-400 group-hover:text-[#9B2226]">Option B</div>
        <div class="mb-4">
          <h2 class="text-3xl font-bold mb-2" style="font-family: 'Cairo', sans-serif;">خط كايرو (عناوين)</h2>
          <p class="text-sm opacity-60">Inter / Roboto (Body text)</p>
        </div>
        <h4 class="text-xl font-bold mb-2 f-amiri"><span class="lang-ar">نظام Modern & Friendly</span><span class="lang-en hidden">Modern & Friendly System</span></h4>
        <p class="text-sm opacity-75 f-amiri leading-relaxed">
          <span class="lang-ar">يركز على السرعة، الحداثة الرقمية، وسهولة المسح البصري. مثالي للتطبيقات السريعة والشباب.</span>
          <span class="lang-en hidden">Focuses on speed, digital modernity, and easy visual scanning. Ideal for fast apps and youth.</span>
        </p>
      </div>
    </div>

    <div class="mt-8 p-4 bg-red-50 border border-red-100 rounded-xl">
        <p class="text-sm f-amiri text-red-900 font-bold">
            <span class="lang-ar">توصية المستشار: نوصي بنظام Heritage & Comfort لتعزيز هوية الفرسان التقليدية مع كفاءة رقمية في نصوص القراءة.</span>
            <span class="lang-en hidden">Consultant recommendation: We recommend Heritage & Comfort to reinforce traditional identity with digital efficiency in reading texts.</span>
        </p>
    </div>
  </section>

  <div class="mt-12 text-center">
    <!-- Button removed as requested -->
  </div>
</DecisionLayout>
