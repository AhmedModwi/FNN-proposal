---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/home/HeroSection.astro';
import WhyDesignMatters from '../components/home/WhyDesignMatters.astro';
import MethodologySection from '../components/home/MethodologySection.astro';
import ReviewInsightsSection from '../components/home/ReviewInsightsSection.astro';
import ResearchMappingSection from '../components/home/ResearchMappingSection.astro';
import SystemIntroduction from '../components/home/SystemIntroduction.astro';
import SystemNavigationSection from '../components/home/SystemNavigationSection.astro';
import FinalPrinciple from '../components/home/FinalPrinciple.astro';
---

<BaseLayout 
  title="المقترح الرقمي - مطعم الفنانين" 
  description="إطار عمل رقمي منظم، صُمم لتقديم الضيافة السودانية على الإنترنت بوضوح ومصداقية."
>
  <main class="home-layout">
    <HeroSection />
    <WhyDesignMatters />
    <MethodologySection />
    <ReviewInsightsSection />
    <ResearchMappingSection />
    <SystemIntroduction />
    <SystemNavigationSection />
    <FinalPrinciple />
  </main>
</BaseLayout>
