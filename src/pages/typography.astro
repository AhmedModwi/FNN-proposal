---
import BaseLayout from '../layouts/BaseLayout.astro';
import SourceLinks from '../components/ui/SourceLinks.astro';
---

<BaseLayout title="النظام الطباعي — Al-Fananin">
  <style is:global>
/* Font Stacks are now globally managed in global.css */
/* Arabic compensation & spacing */
.ar-text { line-height: 1.6; letter-spacing: 0; }
.en-text { line-height: 1.5; letter-spacing: 0.01em; }

/* Presentation Panels */
.specimen-panel {
  min-height: 100vh;
  padding: 4rem 2rem;
  display: flex;
  flex-direction: column;
  background-color: transparent;
  border-bottom: 1px solid rgba(0,0,0,0.05);
}

/* Glyph Preview Area */
.glyph-block {
  word-break: break-all;
  opacity: 0.8;
  margin-bottom: 2rem;
}

/* Table styling */
.meta-table {
  width: 100%;
  border-collapse: collapse;
  text-align: left;
  background: #FFF;
  border-radius: 0.75rem;
  overflow: hidden;
  box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
  border: 1px solid rgba(0,0,0,0.05);
}
.meta-table th, .meta-table td {
  padding: 1rem;
  border-bottom: 1px solid rgba(0,0,0,0.05);
  font-size: 0.85rem;
}
.meta-table th { font-weight: 600; opacity: 0.6; text-transform: uppercase; letter-spacing: 0.05em; background-color: rgba(0,0,0,0.02); }
.meta-table tr:last-child td { border-bottom: none; }

.grid-cols-doc {
  display: grid;
  grid-template-columns: 1fr;
  gap: 3rem;
}
@media (min-width: 1024px) {
  .grid-cols-doc {
    grid-template-columns: 1fr 1fr;
  }
}
  </style>

  <!-- ==========================================
       CHAPTER 0: DATA-DRIVEN ARCHITECTURE
       ========================================== -->
  <section class="bg-[#F8F9FA] border-b border-[#2B1A14]/10 pb-16 pt-16 px-8">
    <div class="max-w-7xl mx-auto w-full">
      <div class="mb-10 text-right">
        <span class="en-text text-xs font-bold tracking-widest uppercase text-gray-500 mb-2 block" dir="ltr" style="text-align:right;">Data-Driven Architecture</span>
        <h2 class="text-3xl font-bold mb-4 f-amiri ar-text">النظام الطباعي — قرار واحد واضح، لا خياران متنافسان</h2>
        <p class="text-lg opacity-80 leading-relaxed max-w-5xl f-cairo ar-text inline-block">
          بعد دراسة الاتجاهين، لم نعد نتعامل مع الصفحة على أنها "مقارنة بين خطين" بل على أنها <strong>نظام طباعي واحد</strong> له أدوار مختلفة. الخط العربي الكلاسيكي <strong>Amiri</strong> يُستخدم حيث نحتاج حضوراً بصرياً ووزناً افتتاحياً، بينما يتولى <strong>Cairo</strong> مهام القراءة السريعة، والواجهات، والنصوص التي يجب أن تُقرأ بسهولة على الشاشات. في الجانب الإنجليزي، يقوم <strong>Playfair Display</strong> بدور العرض، بينما يتولى <strong>Inter</strong> دور النص العملي. الفكرة ليست "إظهار سودانية الخط"؛ هذا ادعاء غير دقيق. الفكرة هي بناء نبرة طباعية تبدو أكثر تميزاً وأقل اعتياداً من المواقع التي تعتمد على القاهرة وحدها من أول الشاشة إلى آخرها.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-white p-6 border rounded-xl shadow-sm">
          <h4 class="font-bold text-[#D9A92B] mb-2 f-amiri ar-text text-xl">1. منطق العرض السريع</h4>
          <p class="text-sm border-b pb-2 mb-2 opacity-60 f-cairo ar-text">النصوص القصيرة، القوائم، الأزرار، والتفاصيل التي يجب أن تُفهم فوراً.</p>
          <p class="text-xs opacity-80 leading-relaxed f-cairo ar-text"><strong>القرار:</strong> هنا يظهر دور Cairo وInter. فالأولوية في هذه الطبقة ليست الشخصية البصرية، بل السرعة والوضوح والقدرة على المسح البصري السريع دون إنهاك العين.</p>
        </div>
        <div class="bg-white p-6 border rounded-xl shadow-sm">
          <h4 class="font-bold text-[#81B29A] mb-2 f-amiri ar-text text-xl">2. منطق القراءة المريحة</h4>
          <p class="text-sm border-b pb-2 mb-2 opacity-60 f-cairo ar-text">فقرات الشرح، التوضيح، والمحتوى الذي يحتاج زمناً أطول داخل الصفحة.</p>
          <p class="text-xs opacity-80 leading-relaxed f-cairo ar-text"><strong>القرار:</strong> تم الحفاظ على ارتفاع سطر مريح وأوزان متزنة لأن الصفحة لا تُعرض كملصق بصري فقط، بل كمستند استشاري يجب أن يشرح ويقنع.</p>
        </div>
        <div class="bg-white p-6 border rounded-xl shadow-sm">
          <h4 class="font-bold text-[#780000] mb-2 f-amiri ar-text text-xl">3. منطق الهيبة والتميّز</h4>
          <p class="text-sm border-b pb-2 mb-2 opacity-60 f-cairo ar-text">العناوين الرئيسية، الجمل الافتتاحية، والنصوص التي نريدها أن تُحسّ قبل أن تُقرأ بالكامل.</p>
          <p class="text-xs opacity-80 leading-relaxed f-cairo ar-text"><strong>القرار:</strong> هنا يدخل Amiri وPlayfair Display. ليس لأنهما "محليان" أو "يمثلان السودان" حرفياً، بل لأنهما يملكان حضوراً تحريرياً كلاسيكياً يرفع قيمة الواجهة ويمنحها شخصية أقل استهلاكاً من الخيارات الشائعة.</p>
        </div>
      </div>
    </div>
  
  <section class="bg-white border-b border-[#2B1A14]/10 py-12 mt-16 px-8 rounded-xl shadow-sm">
    <div class="max-w-7xl mx-auto">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        <a href="https://www.talgat.design/blog/arabic-english-design-experiences-beautiful" class="bg-[#FDFBF7] border rounded-xl p-5 hover:shadow-sm transition block" target="_blank" rel="noopener noreferrer">
          <h3 class="font-bold mb-2 f-amiri ar-text text-xl">تناغم العربية والإنجليزية داخل واجهة واحدة</h3>
          <p class="text-sm opacity-75 f-cairo ar-text">مرجع يوضح لماذا تحتاج الواجهات الثنائية اللغة إلى توافق في الإيقاع البصري لا إلى نسخ حرفي بين الخطين.</p>
          <span class="text-xs font-bold mt-3 inline-block en-text" dir="ltr">Open source</span>
        </a>
        <a href="https://codeguru.ae/blog/designing-arabic-interfaces-right-to-left-ux-done-right/" class="bg-[#FDFBF7] border rounded-xl p-5 hover:shadow-sm transition block" target="_blank" rel="noopener noreferrer">
          <h3 class="font-bold mb-2 f-amiri ar-text text-xl">وضوح القراءة العربية على الشاشة</h3>
          <p class="text-sm opacity-75 f-cairo ar-text">مرجع عملي حول أهمية المقروئية، والهوامش، وارتفاع السطر، وسبب نجاح الخطوط البسيطة في النصوص العملية.</p>
          <span class="text-xs font-bold mt-3 inline-block en-text" dir="ltr">Open source</span>
        </a>
        <a href="https://designsystem.gov.ae/guidelines/typography" class="bg-[#FDFBF7] border rounded-xl p-5 hover:shadow-sm transition block" target="_blank" rel="noopener noreferrer">
          <h3 class="font-bold mb-2 f-amiri ar-text text-xl">أهمية السلالم الطباعية والخطوط البديلة</h3>
          <p class="text-sm opacity-75 f-cairo ar-text">مرجع من نظام تصميم رسمي يبرر أهمية التسلسل الهرمي الطباعي، واستقرار الخطوط، ووجود بدائل موثوقة عند فشل التحميل.</p>
          <span class="text-xs font-bold mt-3 inline-block en-text" dir="ltr">Open source</span>
        </a>
      </div>
    </div>
  </section>

  </section>

  <!-- ==========================================
       DIRECTION 1: Display & Editorial Layer (AMIRI / PLAYFAIR)
       ========================================== -->
  <section class="specimen-panel">
    <div class="max-w-7xl mx-auto w-full flex-1 flex flex-col">
      
      <!-- Header -->
      <header class="mb-12 border-b border-[#4A3B32]/10 pb-6">
        <p class="text-sm font-bold uppercase tracking-widest opacity-60 mb-2 en-text f-inter" dir="ltr" style="text-align:left;">Role 1</p>
        <h1 class="text-4xl md:text-5xl font-normal f-playfair en-text" dir="ltr" style="text-align:left;">Display & Editorial Layer</h1>
        <p class="text-xl mt-3 opacity-80 f-amiri ar-text">Amiri (Arabic) + Playfair Display (English)</p>
      </header>

      <div class="grid-cols-doc flex-1">
        
        <!-- ARABIC COLUMN -->
        <div class="flex flex-col">
          <div class="mb-8">
            <h2 class="text-4xl font-bold f-amiri ar-text mb-4">لماذا اختير Amiri للعناوين العربية؟</h2>
            <p class="text-[20px] opacity-80 f-cairo ar-text max-w-xl">
              ليس لأننا ندّعي أنه "خط سوداني"، فهذا غير دقيق. اختير Amiri لأنه يقدّم شيئاً لا يقدمه Cairo: <strong>حضور افتتاحي مميز</strong>. عندما يظهر في العنوان الرئيسي أو في عبارة محورية، فإنه يعطي الصفحة وزناً تحريرياً ونبرة أكثر جدية وتميزاً. هذه هي وظيفته: أن يرفع السقف البصري للعناوين، لا أن يتحمل عبء القراءة اليومية الطويلة.
            </p>
          </div>

          <div class="mb-12 border-t border-[#4A3B32]/10 pt-6">
            <h3 class="text-2xl font-bold f-amiri ar-text mb-2">الخط البديل (Fallback Font)</h3>
            <p class="text-[18px] opacity-70 fb-serif ar-text max-w-lg" style="line-height:1.7;">
              بناءً على الطابع التراثي والفخم، تم اختيار عائلة خطوط (Serif) الكلاسيكية وعلى رأسها خط (Georgia) ليكون خط التراجع البديل. يضمن هذا الاختيار الحفاظ على الروح الأنيقة والأدبية للنص حتى عند انقطاع الاتصال. تُقرأ هذه الفقرة المعروضة أمامك بالخط البديل.
            </p>
          </div>

          <div class="mb-12">
            <p class="text-xs font-bold uppercase tracking-wide opacity-50 mb-3 f-amiri">محارف العربية</p>
            <div class="glyph-block f-amiri ar-text text-3xl leading-relaxed">
              أبجد هوز حطي كلمن سعفص قرشت ثخذ ضظغ<br>
              ١٢٣٤٥٦٧٨٩٠<br>
              ؟ ! ، . : ؛ / - ( )
            </div>
          </div>

          <div class="mb-12">
            <p class="text-xs font-bold uppercase tracking-wide opacity-50 mb-4 f-amiri">السلم الطباعي (Arabic Scale)</p>
            <div class="space-y-6 f-amiri ar-text">
              <div><span class="text-[48px] font-bold leading-tight block">عرض رئيسي</span><span class="text-xs opacity-50 font-sans">Display — 48px, Bold</span></div>
              <div><span class="text-[38px] font-bold leading-tight block">عنوان أول</span><span class="text-xs opacity-50 font-sans">H1 — 38px, Bold</span></div>
              <div><span class="text-[30px] font-bold leading-tight block">عنوان ثانٍ</span><span class="text-xs opacity-50 font-sans">H2 — 30px, Bold</span></div>
              <div><span class="text-[24px] font-bold leading-tight block">عنوان ثالث</span><span class="text-xs opacity-50 font-sans">H3 — 24px, Bold</span></div>
            </div>
          </div>
        </div>

        <!-- ENGLISH COLUMN -->
        <div class="flex flex-col" dir="ltr" style="text-align: left;">
          <div class="mb-8">
            <h2 class="text-[34px] font-semibold f-playfair en-text mb-4">Why Playfair completes the Arabic display layer</h2>
            <p class="text-[16px] opacity-80 f-inter en-text max-w-xl">
              If Amiri gives the Arabic side presence, Playfair Display gives the English side an equivalent editorial tone. The goal is not to make English imitate Arabic, but to make both sides feel as if they belong to the same publication. That is why Playfair works here: it has enough elegance for headlines, enough contrast to feel premium, and enough restraint to avoid turning the page into costume.
            </p>
          </div>

          <div class="mb-12 border-t border-[#4A3B32]/10 pt-6">
            <h3 class="text-xl font-semibold f-playfair en-text mb-2 text-inherit">Classical Fallback Font</h3>
            <p class="text-[15px] opacity-70 fb-serif en-text max-w-lg text-inherit">
              To maintain the editorial and premium aesthetic, a traditional native serif stack (led by Georgia) is employed as the fallback. This ensures the reading experience remains literary and structured even if the web font fails. This text block is actively demonstrating the fallback serif style.
            </p>
          </div>

          <div class="mb-12">
            <p class="text-xs font-bold uppercase tracking-widest opacity-50 mb-3 f-inter">Latin Glyphs</p>
            <div class="glyph-block f-playfair en-text text-2xl leading-relaxed italic">
              ABCDEFGHIJKLMNOPQRSTUVWXYZ<br>
              abcdefghijklmnopqrstuvwxyz<br>
              0123456789<br>
              ! ? , . : ; / - ( )
            </div>
          </div>

          <div class="mb-12">
            <p class="text-xs font-bold uppercase tracking-widest opacity-50 mb-4 f-inter">English Scale</p>
            <div class="space-y-6 f-playfair en-text">
              <div><span class="text-[42px] font-bold italic leading-tight block">Display</span><span class="text-xs opacity-50 font-sans not-italic">Display — 42px, Bold Italic</span></div>
              <div><span class="text-[34px] font-bold leading-tight block">Heading 1</span><span class="text-xs opacity-50 font-sans">H1 — 34px, Bold</span></div>
              <div><span class="text-[26px] font-bold leading-tight block">Heading 2</span><span class="text-xs opacity-50 font-sans">H2 — 26px, Bold</span></div>
              <div><span class="text-[22px] font-semibold italic leading-tight block">Heading 3</span><span class="text-xs opacity-50 font-sans not-italic">H3 — 22px, SemiBold Italic</span></div>
            </div>
          </div>
        </div>
        
      </div>

      <!-- Metadata Table -->
      <div class="mt-auto pt-12 border-t border-[#4A3B32]/10" dir="ltr">
        <p class="text-xs font-bold uppercase tracking-widest opacity-50 mb-4 f-inter" style="text-align:left;">Technical Specifications — Display & Editorial</p>
        <div class="overflow-x-auto">
          <table class="meta-table f-inter en-text" style="text-align:left;">
            <thead>
              <tr>
                <th style="text-align:left;">Role</th>
                <th style="text-align:left;">Font Family</th>
                <th style="text-align:left;">Size (Mobile-Desktop)</th>
                <th style="text-align:left;">Weight</th>
                <th style="text-align:left;">Line Height</th>
                <th style="text-align:left;">Usage</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Arabic Display</td>
                <td>Amiri<br><span style="font-size:0.75rem; opacity:0.6; font-family:monospace;">Georgia, "Times New Roman", Times, serif</span></td>
                <td>24px - 48px</td>
                <td>400, 700</td>
                <td>1.3 - 1.6</td>
                <td>Hero, section titles, pull quotes, display moments</td>
              </tr>
              <tr>
                <td>English Display</td>
                <td>Playfair Display<br><span style="font-size:0.75rem; opacity:0.6; font-family:monospace;">Georgia, "Times New Roman", Times, serif</span></td>
                <td>22px - 42px</td>
                <td>400, 600, 700</td>
                <td>1.2 - 1.4</td>
                <td>Hero headlines, section titles, editorial emphasis</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </section>


  <!-- ==========================================
       DIRECTION 2: Body & Interface Layer (CAIRO / INTER)
       ========================================== -->
  <section class="specimen-panel bg-white pb-32">
    <div class="max-w-7xl mx-auto w-full flex-1 flex flex-col">
      
      <!-- Header -->
      <header class="mb-12 border-b border-[#2B1A14]/10 pb-6">
        <p class="text-sm font-bold uppercase tracking-widest opacity-60 mb-2 en-text f-inter" dir="ltr" style="text-align:left;">Role 2</p>
        <h1 class="text-4xl md:text-5xl font-black f-playfair en-text" dir="ltr" style="text-align:left;">Body & Interface Layer</h1>
        <p class="text-xl mt-3 opacity-80 f-cairo ar-text">Cairo (Arabic) + Inter (English)</p>
      </header>

      <div class="grid-cols-doc flex-1">
        
        <!-- ARABIC COLUMN -->
        <div class="flex flex-col">
          <!-- Text Explanation -->
          <div class="mb-8">
            <h2 class="text-3xl font-bold f-amiri ar-text mb-4">لماذا اختير Cairo للنص العربي العملي؟</h2>
            <p class="text-[18px] opacity-80 f-cairo ar-text max-w-xl">
              لأن وظيفة هذا الخط هنا عملية قبل أن تكون تعبيرية. النصوص الطويلة، عناصر الواجهة، الشروح، العناوين الفرعية، وأسماء الحقول تحتاج خطاً يقرأ بسرعة ويحتمل الأحجام الصغيرة من دون أن يفقد توازنه. Cairo ينجح هنا لأنه واضح على الشاشة، مألوف بدرجة كافية كي لا يربك المستخدم، لكنه لا يجرّ الصفحة كلها إلى نبرة تقنية باردة. بهذا المعنى، هو خط الخدمة اليومية للنظام.
            </p>
          </div>

          <!-- Fallback Explanation -->
          <div class="mb-12 border-t border-[#2B1A14]/10 pt-6">
            <h3 class="text-xl font-bold f-amiri ar-text mb-2">الخط البديل (Fallback Font)</h3>
            <p class="text-[16px] opacity-70 fb-sans ar-text max-w-lg">
              تم الاعتماد على خطوط النظام الافتراضية (System-UI) كبديل آمن وسريع لضمان سرعة التحميل وتفادي أي تشوه في التصميم في حال لم يكتمل تحميل الخط الأساسي. تُقرأ هذه الفقرة المعروضة أمامك حالياً باستخدام الخط البديل الفعلي لتوضيح التوافق الهيكلي.
            </p>
          </div>

          <!-- Glyphs -->
          <div class="mb-12">
            <p class="text-xs font-bold uppercase tracking-wide opacity-50 mb-3 f-cairo">محارف العربية</p>
            <div class="glyph-block f-cairo ar-text text-2xl md:text-3xl leading-relaxed font-semibold">
              أبجد هوز حطي كلمن سعفص قرشت ثخذ ضظغ<br>
              ١٢٣٤٥٦٧٨٩٠<br>
              ؟ ! ، . : ؛ / - ( )
            </div>
          </div>

          <!-- Type Scale -->
          <div class="mb-12">
            <p class="text-xs font-bold uppercase tracking-wide opacity-50 mb-4 f-cairo">السلم الطباعي (Arabic Scale)</p>
            <div class="space-y-6 f-cairo ar-text">
              <div><span class="text-[20px] font-normal leading-relaxed block">نص أساسي للفقرات والشرح</span><span class="text-xs opacity-50">Body — 20px, Regular</span></div>
              <div><span class="text-[14px] font-normal block">نص صغير للتلميحات والملاحظات</span><span class="text-xs opacity-50">Small — 14px, Regular</span></div>
            </div>
          </div>
        </div>

        <!-- ENGLISH COLUMN -->
        <div class="flex flex-col" dir="ltr" style="text-align: left;">
          <!-- Text Explanation -->
          <div class="mb-8">
            <h2 class="text-[28px] font-bold f-playfair en-text mb-4">Why Inter supports the Arabic decision</h2>
            <p class="text-[16px] opacity-80 f-inter en-text max-w-xl">
              Inter was chosen for the same reason Cairo was: it keeps functional reading fast. Buttons, metadata, paragraphs, labels, and small interface details need a Latin font that stays calm under pressure. Inter gives the English side a clean digital rhythm without competing with the display layer, which makes the bilingual system feel coordinated rather than split into two unrelated personalities.
            </p>
          </div>

          <!-- Fallback Explanation -->
          <div class="mb-12 border-t border-[#2B1A14]/10 pt-6">
            <h3 class="text-lg font-bold f-playfair en-text mb-2">System Fallback Font</h3>
            <p class="text-[14px] opacity-70 fb-sans en-text max-w-lg">
              System-UI fonts are designated as a robust fallback. They guarantee zero layout shifts and instant readability if the primary web font fails to load. This paragraph is actively rendered in the fallback system font to demonstrate the resulting visual structure.
            </p>
          </div>

          <!-- Glyphs -->
          <div class="mb-12">
            <p class="text-xs font-bold uppercase tracking-widest opacity-50 mb-3 f-inter">Latin Glyphs</p>
            <div class="glyph-block f-inter en-text text-xl md:text-2xl leading-relaxed font-medium">
              ABCDEFGHIJKLMNOPQRSTUVWXYZ<br>
              abcdefghijklmnopqrstuvwxyz<br>
              0123456789<br>
              ! ? , . : ; / - ( )
            </div>
          </div>

          <!-- Type Scale -->
          <div class="mb-12">
            <p class="text-xs font-bold uppercase tracking-widest opacity-50 mb-4 f-inter">English Scale</p>
            <div class="space-y-6 f-inter en-text">
              <div><span class="text-[16px] font-normal leading-relaxed block">Body text for paragraphs and descriptions</span><span class="text-xs opacity-50">Body — 16px, Regular</span></div>
              <div><span class="text-[13px] font-normal block">Small text for hints and notes</span><span class="text-xs opacity-50">Small — 13px, Regular</span></div>
            </div>
          </div>
        </div>
        
      </div>

      <!-- Metadata Table -->
      <div class="mt-auto pt-12 border-t border-[#2B1A14]/10" dir="ltr">
        <p class="text-xs font-bold uppercase tracking-widest opacity-50 mb-4 f-inter" style="text-align:left;">Technical Specifications — Body & Interface Layer</p>
        <div class="overflow-x-auto">
